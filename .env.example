# --- Database ---
# PostgreSQL Connection String
DATABASE_URL="postgresql://user:password@localhost:5432/jct_db"
# Optional (Defaults to 10 if not provided)
DATABASE_CON_LIMIT="10"

# --- App Configuration ---
# The public URL of the app
NEXT_PUBLIC_APP_URL="https://jctjournals.com"

# --- Authentication ---
# JWT Secret must be at least 32 characters long for security
JWT_SECRET_KEY="your_super_secret_jwt_key_that_is_at_least_32_characters_long"

# --- Email (Nodemailer) ---
EMAIL_USER="your-email@example.com"
EMAIL_PASSWORD="your-app-password-or-smtp-password"

# --- Cloudflare R2 (Storage) ---
R2_ENDPOINT="https://<YOUR_ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your_r2_access_key"
R2_SECRET_ACCESS_KEY="your_r2_secret_key"
R2_BUCKET_NAME="your_r2_bucket_name"
# Public URL to access stored files
R2_PUBLIC_ACCESS_ENDPOINT="https://pub-xxxxxxxxxxxxx.r2.dev"

# --- Razorpay (Payments) ---
# Server-side Razorpay Key ID
RAZORPAY_KEY="rzp_test_your_server_key"
RAZORPAY_SECRET_KEY="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# Client-side Razorpay Key ID
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_client_key"

# --- REDIS (for background jobs) ---
# Redis connection string
REDIS_URL="redis://localhost:6379"
REDIS_TLS="true" # or "false", depending on your redis host setup